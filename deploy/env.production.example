# Скопируйте в deploy/.env и заполните. Не коммитьте .env с секретами.

SDOCS_MCP_IMAGE_TAG=0.4.0

# Путь к YAML на хосте (bind-mount в контейнер как /etc/sdocs-mcp/config.yaml)
SDOCS_MCP_CONFIG_HOST_PATH=/etc/sdocs-mcp/config.yaml

# Слушать только localhost на хосте (за reverse proxy) или 0.0.0.0
SDOCS_MCP_UI_BIND=127.0.0.1
SDOCS_MCP_UI_PORT=8888

# Внутри контейнера:
SDOCS_MCP_CONFIG=/etc/sdocs-mcp/config.yaml
SDOCS_MCP_UI_HOST=0.0.0.0
# Встроенный MCP на том же порту, что UI: URL http://<host>:8888/mcp
SDOCS_MCP_EMBED_MCP=true
SDOCS_MCP_UI_WORKERS=1
# Stateless Streamable HTTP: без привязки запросов к сессии на сервере — удобно за L7-балансировщиком
# без sticky, при replicas>1 и при SDOCS_MCP_UI_WORKERS>1. Иначе держите воркеры = 1.
# SDOCS_MCP_STATELESS_HTTP=true
SDOCS_MCP_LOG_LEVEL=info

# Обязательно в проде для публичного bind:
SDOCS_MCP_UI_TOKEN=change-me-long-random-ui-token
SDOCS_MCP_METRICS_TOKEN=change-me-long-random-metrics-token
SDOCS_MCP_METRICS_REQUIRE_TOKEN=true

SDOCS_MCP_UI_ENABLE_INVOKE=false
SDOCS_MCP_UI_ENABLE_SEED=false
SDOCS_MCP_UI_RATE_LIMIT_RPM=120
SDOCS_MCP_METRICS_RATE_LIMIT_RPM=240
# Только каталог приложения (volume sdocs-mcp-data → /app/data)
SDOCS_MCP_UI_AUDIT_LOG_PATH=/app/data/logs/ui-audit.log
# Опционально: кто дергает MCP при stdio или без заголовка в HTTP
# SDOCS_MCP_AUDIT_CALLER_ID=cursor-workspace-1

# За reverse proxy с проверкой Host (опционально):
# SDOCS_MCP_UI_TRUSTED_HOSTS=ui.example.com,localhost
