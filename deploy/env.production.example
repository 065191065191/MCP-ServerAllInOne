# Скопируйте в deploy/.env и заполните значения. Не коммитьте .env с секретами.
#
# Все переменные ниже — окружение процесса/контейнера sdocs-mcp-ui.
# Значения в "config.yaml" задаются отдельно (см. config.example.yaml).

# ───── Тег образа (используется docker-compose.prod.yml) ─────
SDOCS_MCP_IMAGE_TAG=0.6.5

# ───── Где конфиг ─────
# На хосте — абсолютный путь до YAML (будет bind-mount в контейнер).
SDOCS_MCP_CONFIG_HOST_PATH=/etc/sdocs-mcp/config.yaml
# Внутри контейнера приложение ищет конфиг по этому пути:
SDOCS_MCP_CONFIG=/etc/sdocs-mcp/config.yaml

# ───── Сеть ─────
# На хосте: 127.0.0.1 — слушать только локально (за nginx/Traefik); 0.0.0.0 — на все интерфейсы.
SDOCS_MCP_UI_BIND=127.0.0.1
SDOCS_MCP_UI_PORT=8888
# Внутри контейнера — слушаем все интерфейсы; наружу ограничивает SDOCS_MCP_UI_BIND.
SDOCS_MCP_UI_HOST=0.0.0.0

# ───── Один порт = UI + MCP + /metrics ─────
# Зачем: один внешний порт обслуживает дашборд, MCP Streamable HTTP на /mcp и /metrics.
SDOCS_MCP_EMBED_MCP=true

# ───── Воркеры и stateless ─────
# При EMBED_MCP=true сессии Streamable HTTP живут в памяти воркера.
# Если воркеров > 1 ИЛИ реплик > 1 без sticky-сессий — обязательно включите stateless.
SDOCS_MCP_UI_WORKERS=1
# SDOCS_MCP_STATELESS_HTTP=true        # включить при workers>1 или replicas>1 без sticky

# ───── Логирование ─────
SDOCS_MCP_LOG_LEVEL=info

# ───── Безопасность ─────
# UI-токен: Bearer для /api/*. В проде с публичным bind задавать обязательно.
SDOCS_MCP_UI_TOKEN=change-me-long-random-ui-token
# Токен для /metrics + строгая проверка (метрики могут раскрыть внутренние имена).
SDOCS_MCP_METRICS_TOKEN=change-me-long-random-metrics-token
SDOCS_MCP_METRICS_REQUIRE_TOKEN=true
# Опасные операции в UI отключены: UI только для наблюдения.
SDOCS_MCP_UI_ENABLE_INVOKE=false
SDOCS_MCP_UI_ENABLE_SEED=false
# Антифлуд (запросов/минуту).
SDOCS_MCP_UI_RATE_LIMIT_RPM=120
SDOCS_MCP_METRICS_RATE_LIMIT_RPM=240

# Журнал событий UI в JSONL (auth_failed, rate_limit, mcp_invoke_*).
# Только под /app/data (volume sdocs-mcp-data → /app/data).
SDOCS_MCP_UI_AUDIT_LOG_PATH=/app/data/logs/ui-audit.log

# За reverse proxy с проверкой Host (опционально):
# SDOCS_MCP_UI_TRUSTED_HOSTS=ui.example.com,localhost

# Кто вызвал MCP при stdio или без HTTP-заголовка (для аудита):
# SDOCS_MCP_AUDIT_CALLER_ID=cursor-workspace-1

# ───── Пароли почты (НЕ в YAML, только через ENV) ─────
# Имена этих переменных соответствуют полям *_env в config.yaml → modules.mail.
SDOCS_MCP_MAIL_IMAP_USER=sdocs_mcp@example.com
SDOCS_MCP_MAIL_IMAP_PASSWORD=change-me-imap-password
SDOCS_MCP_MAIL_SMTP_USER=sdocs_mcp@example.com
SDOCS_MCP_MAIL_SMTP_PASSWORD=change-me-smtp-password
