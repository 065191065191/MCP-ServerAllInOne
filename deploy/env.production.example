# Скопируйте в deploy/.env и заполните. Не коммитьте .env с секретами.

STACK_MCP_IMAGE_TAG=0.2.8

# Путь к YAML на хосте (bind-mount в контейнер как /etc/stack-mcp/config.yaml)
STACK_MCP_CONFIG_HOST_PATH=/etc/stack-mcp/config.yaml

# Слушать только localhost на хосте (за reverse proxy) или 0.0.0.0
STACK_MCP_UI_BIND=127.0.0.1
STACK_MCP_UI_PORT=8888

# Внутри контейнера:
STACK_MCP_CONFIG=/etc/stack-mcp/config.yaml
STACK_MCP_UI_HOST=0.0.0.0
# Встроенный MCP на том же порту, что UI: URL http://<host>:8888/mcp (для воркеров >1 может ломать сессии MCP)
STACK_MCP_EMBED_MCP=true
STACK_MCP_UI_WORKERS=1
STACK_MCP_LOG_LEVEL=info

# Обязательно в проде для публичного bind:
STACK_MCP_UI_TOKEN=change-me-long-random-ui-token
STACK_MCP_METRICS_TOKEN=change-me-long-random-metrics-token
STACK_MCP_METRICS_REQUIRE_TOKEN=true

STACK_MCP_UI_ENABLE_INVOKE=false
STACK_MCP_UI_ENABLE_SEED=false
STACK_MCP_UI_RATE_LIMIT_RPM=120
STACK_MCP_METRICS_RATE_LIMIT_RPM=240
STACK_MCP_UI_AUDIT_LOG_PATH=/app/logs/ui-audit.log

# За reverse proxy с проверкой Host (опционально):
# STACK_MCP_UI_TRUSTED_HOSTS=ui.example.com,localhost
